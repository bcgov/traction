# Copy to `.env` in this directory and set values. `.env` is gitignored.
# python-dotenv loads `.env` automatically when you run `run.py`.

TRACTION_TENANT_PROXY_BASE=http://localhost:8032

# Use either Bearer (Tenant UI / wallet token) or API key — not both required in docs, but only one is used if both set (API key wins).
# TRACTION_TENANT_TOKEN=
# TRACTION_TENANT_API_KEY=

# Optional WebVH overrides
# WEBVH_CONFIGURE_MODE=invitation
# WEBVH_WITNESS_INVITATION=didcomm://?oob=...
# WEBVH_DID_ALIAS=my-webvh-alias
# WEBVH_NAMESPACE=default
# WEBVH_SERVER_URL=
