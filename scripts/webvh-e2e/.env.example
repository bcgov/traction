# Copy to `.env` in this directory. `run.py` loads it via python-dotenv (does not override existing shell env).

TRACTION_TENANT_PROXY_BASE=https://traction-sandbox-tenant-proxy.apps.silver.devops.gov.bc.ca
TRACTION_ISSUER_TENANT_TOKEN=
TRACTION_HOLDER_TENANT_TOKEN=

# Optional WebVH (see README for other variables)
# WEBVH_CREATE_ALIAS=

# Optional full E2E flow (schema, cred-def w/ revocation, OOB, issue, verify, revoke)
# WEBVH_E2E_SCHEMA_NAME=WebVHE2EHarness
# WEBVH_E2E_SCHEMA_VERSION=1.0
# WEBVH_E2E_SCHEMA_ATTRS=name,score
# WEBVH_E2E_REVOCATION_REGISTRY_SIZE=4
# WEBVH_E2E_CRED_VALUES={"name":"Alice","score":"100"}
