# Copy to `.env` in this directory and set values. `.env` is gitignored.
# python-dotenv loads `.env` automatically when you run `run.py`.

TRACTION_TENANT_PROXY_BASE=http://localhost:8032

# Required: issuer tenant — Bearer JWT (Tenant UI / wallet)
# TRACTION_ISSUER_TENANT_TOKEN=
#
# Required for oob-didexchange-webvh-didcomm / profile new-issuer-webvh / profile all: second tenant JWT (must differ from issuer)
# TRACTION_HOLDER_TENANT_TOKEN=

# Optional WebVH overrides (invitation is normally fetched from the WebVH server using plugin_config)
# WEBVH_WITNESS_INVITATION=didcomm://?oob=...
# WEBVH_DID_ALIAS=a1b2c3d4  # optional; default is random 8 hex chars (namespace is webvh-e2e)
# WEBVH_NAMESPACE=other-ns  # optional; harness default is webvh-e2e
# WEBVH_SERVER_URL=
# webvh-create: add DIDComm service to the new did:webvh (plugin ``options.didcomm``). Default on; set 0/false/off to skip.
# WEBVH_CREATE_DIDCOMM=1

# AnonCreds schema: issuerId = same did:webvh as webvh-create (override only if needed)
# WEBVH_SCHEMA_ISSUER_ID=did:webvh:...
# WEBVH_SCHEMA_NAME=webvh-e2e-preferences
# WEBVH_SCHEMA_VERSION=1.0
# WEBVH_SCHEMA_ATTRS=name,score

# Cred def (publish-cred-def-webvh): revocation on; registry size defaults to 4
# WEBVH_CRED_DEF_TAG=webvh-e2e
# WEBVH_REVOCATION_REGISTRY_SIZE=4
# WEBVH_REV_ACTIVE_WAIT_ATTEMPTS=30
# WEBVH_REV_ACTIVE_WAIT_SEC=1
# If active-registry returns 5xx but revocation is on the ledger, pass publish-cred-def-webvh anyway:
# WEBVH_REV_ACTIVE_SOFT_FAIL=1
#
# upgrade-anoncreds-wallet phase: poll /settings after POST /anoncreds/wallet/upgrade
# WEBVH_WALLET_UPGRADE_POLL_SEC=1
# WEBVH_WALLET_UPGRADE_TIMEOUT_SEC=180
#
# oob-didexchange-webvh-didcomm: OOB aliases + connection poll
# Issuer invitation uses use_did = did:webvh from webvh-create; override if reusing a run:
# WEBVH_OOB_USE_DID=did:webvh:...
# WEBVH_OOB_ISSUER_ALIAS=webvh-e2e-issuer
# WEBVH_OOB_HOLDER_ALIAS=webvh-e2e-holder
# WEBVH_CONNECT_POLL_SEC=1
# WEBVH_CONNECT_TIMEOUT_SEC=120
# WEBVH_OOB_MULTI_USE=0
#
# issue-webvh (after oob-didexchange-webvh-didcomm + publish-cred-def-webvh)
# WEBVH_ISSUE_VALUES=WebVH E2E Holder,95
# WEBVH_ISSUE_VALUES_JSON={"name":"Alice","score":"100"}
# WEBVH_ISSUE_AUTO_ISSUE=false
# WEBVH_ISSUE_POLL_SEC=1
# WEBVH_ISSUE_TIMEOUT_SEC=180
# Re-run issue only (optional):
# WEBVH_ISSUE_ISSUER_CONNECTION_ID=
# WEBVH_ISSUE_HOLDER_CONNECTION_ID=
#
# verify-webvh (present-proof 2.0 / AnonCreds; non_revoked on attributes by default)
# WEBVH_VERIFY_NON_REVOKED=1
# WEBVH_VERIFY_POLL_SEC=1
# WEBVH_VERIFY_TIMEOUT_SEC=180
# WEBVH_VERIFY_AUTO_VERIFY=false
# WEBVH_VERIFY_COMMENT=webvh-e2e verify-webvh
# WEBVH_VERIFY_PROOF_NAME=webvh-e2e-proof
#
# revoke-webvh then verify-webvh-post-revoke (expects second proof not verified)
# WEBVH_REVOKE_CRED_EX_ID=   # default: issuer cred_ex from issue-webvh in same run
# WEBVH_REVOKE_PUBLISH=1
# WEBVH_REVOKE_RECORD_POLL_SEC=1
# WEBVH_REVOKE_RECORD_TIMEOUT_SEC=90
# Optional holder revocation notification (needs connection_id + thread_id from cred ex).
# Harness always sends explicit ``notify`` false/true so tenant ``revocation.notify`` defaults do not 400.
# WEBVH_REVOKE_NOTIFY=0
# WEBVH_REVOKE_NOTIFY_VERSION=v2_0
# WEBVH_VERIFY_POST_REVOKE_PROOF_NAME=webvh-e2e-proof-post-revoke
# WEBVH_VERIFY_POST_REVOKE_COMMENT=webvh-e2e expect unverifiable (revoked)
