{
  "name": "tenant-ui-frontend",
  "private": true,
  "version": "1.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"{src,test,scripts}/**/*.{ts,js,vue}\" \"*.{js,ts}\" --max-warnings=0",
    "lintfix": "eslint \"{src,test,scripts}/**/*.{ts,js,vue}\" \"*.{js,ts}\" --fix",
    "i18n:fill-keys": "node ./scripts/i18n/fillKeys.js",
    "i18n:common-keys": "node ./scripts/i18n/commonKeys.js",
    "i18n:sort-keys": "node ./scripts/i18n/sortKeys.js",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@intlify/unplugin-vue-i18n": "^11.1.2",
    "@jsonforms/core": "^3.7.0",
    "@jsonforms/vue": "^3.7.0",
    "@jsonforms/vue-vanilla": "^3.7.0",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "json-editor-vue": "^0.18.1",
    "marked": "^18.0.3",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^3.53.1",
    "qrcode.vue": "^3.9.0",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^5.0.6",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@pinia/testing": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "flat": "^6.0.1",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.2",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7",
    "whatwg-fetch": "^3.6.20"
  }
}
